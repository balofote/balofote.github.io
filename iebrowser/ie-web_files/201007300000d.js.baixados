/* Specify the Report Suite ID(s) to track here */
var s_trr_account="";
var s_trr=s_gi(s_trr_account);
var lnk_filter,lnk_type;

/************************** CONFIG SECTION **************************/
/* You may add or alter any code config here. */
/* Basic Config */
s_trr.currencyCode="USD"
s_trr.charSet="ISO-8859-1"
s_trr.cookieDomainPeriods=3

/* Link Tracking Config */
s_trr.trackDownloadLinks=true
s_trr.trackExternalLinks=false
s_trr.trackInlineStats=true
s_trr.linkDownloadFileTypes="cab,cod,exe,zip,wav,mp3,mov,mpg,avi,wmv,doc,pdf,prc,xls,qt,nsv,ra,ram,rm,wsz,wal,dmg,sit,sitx,gz,tar"
s_trr.linkInternalFilters="javascript:,.terra.,terra.,.trrsf."
s_trr.linkLeaveQueryString=false
s_trr.linkTrackVars="None"
s_trr.linkTrackEvents="None"

/********************************************************************
 * Config variables (should be above doPlugins section)
********************************************************************/
/* Page Name Plugin Config */
s_trr.siteID=""
s_trr.defaultPage=""  // may want to populate with value from logic
s_trr.queryVarsList="id"
s_trr.pathExcludeDelim=";"
s_trr.pathConcatDelim=">"
s_trr.pathExcludeList=""

/* WARNING: Changing any of the below variables will cause drastic
changes to how your visitor data is collected.  Changes should only be
made when instructed to do so by your account manager. */
s_trr.visitorNamespace="terra"
s_trr.trackingServer="terra.112.2o7.net"
s_trr.dc=112

/* Visit Depth Config var */
s_trr.ActionDepthTest=true

/* Plugin Config */
s_trr.usePlugins=true
function s_doPlugins(s_trr){
	s_trr.referrer=s_trr.referrer?s_trr.referrer:document.referrer;
	s_trr.referrer=s_trr.referrer.toLowerCase();

	/* Capture campaign identifier parameter from URL */
	if (!s_trr.campaign){s_trr.campaign=s_trr.getQueryParam('ncid');}
	if (!s_trr.eVar16){s_trr.eVar16=s_trr.getQueryParam('icid');}
	if (!s_trr.eVar17){s_trr.eVar17=s_trr.getQueryParam('ncid');}
	if (!s_trr.eVar18){s_trr.eVar18=s_trr.getQueryParam('ncid');}

	/* Plugin: getValOnce_v1.0 get value once per session */
	s_trr.campaign=s_trr.getValOnce(s_trr.getQueryParam('ncid'),'s_campaign',0);
	s_trr.eVar16=s_trr.getValOnce(s_trr.getQueryParam('icid'),'s_var_16',0);
	s_trr.eVar17=s_trr.getValOnce(s_trr.getQueryParam('ncid'),'s_var_17',0);
	s_trr.eVar18=s_trr.getValOnce(s_trr.getQueryParam('ncid'),'s_var_18',0);
	s_trr.eVar19=s_trr.getValOnce(s_trr.eVar19,'s_var_19',0);
	s_trr.eVar20=s_trr.getValOnce(s_trr.eVar20,'s_var_20',0);

	if(typeof s_trr.pfxID=='undefined'||s_trr.pfxID=="")s_trr.pfxID='unset';
	if(typeof s_trr.channel=='undefined'||s_trr.channel=="")s_trr.channel=s_trr.pfxID;

	/* Allows a domain to be included as internal even though external on a page by page basis */
	lnk_type=""?"e":lnk_type
	s_trr.linkHandler(lnk_filter,lnk_type)

	/* Plugin: getNewRepeat 1.0 */
	s_trr.prop47=s_trr.getNewRepeat();
	s_trr.eVar20=s_trr.getNewRepeat();

	/* Plugin: getDaysSinceLastVisit 1.0 */
	s_trr.eVar19=s_trr.getDaysSinceLastVisit('s_v19');

	/* Plugin: detectRIA v0.1 */
	// set on every page with default max versions
	s_trr.detectRIA('s_ria','prop48','prop49','','','');

	/* channelManager v2.4 */
	s_trr.channelManager('ncid','','c_m1',1,'c_m2');
	s_trr._campaign=s_trr._campaign=="Direct Load"?"":s_trr._campaign
	s_trr.campaign=s_trr._campaign;
	s_trr.eVar46=s_trr._keywords;
	s_trr.eVar47=s_trr._channel;

	/* campaign and channel stacking */	
	s_trr.eVar48=s_trr.crossVisitParticipation(s_trr._campaign,'v48','90','5','>','',0);
	s_trr.eVar49=s_trr.crossVisitParticipation(s_trr._channel,'v49','90','5','>','',0);

	/* Entry Bounce Rate Tracking */
	s_trr.bounceCheck(s_trr.campaign,'event19','event20')

	/* pageView event tracking */
	s_trr.events=s_trr.apl(s_trr.events,'event1',',',1) //s_trr.events="event1";

	/* getActionDepth v1.0 */
	if(s_trr.ActionDepthTest){
		s_trr.pdvalue=s_trr.getActionDepth("s_depth");
		if(s_trr.pdvalue==5)s_trr.events=s_trr.apl(s_trr.events,'event15',',',1);
		s_trr.ActionDepthTest=false;
    }

	/* visit of 15 minutes or more */
	s_trr.thresholdCheck=s_trr.getTimeConsumed('900')	
	s_trr.events=s_trr.thresholdCheck==1?s_trr.apl(s_trr.events,'event16',',',1):s_trr.events;

	/* Engagement Score event18, eVar41 */
	s_trr.visitorEngagement({
                eng_evar:['eVar41'],
                eng_event:['event18'],
                eng_arr:[
			['events','event15',1,5], //visit of 5 pv or more
			['events','event16',1,5], //visit of 15 minutes or longer
			['events','event17',5,2], //Internal Search
			['events','event12',3,2], //Imprimir
			['events','event13',3,2], //Enviar para amigos
			['events','event14',3,2] //Comentar
		]
    });
	if (s_trr.eVar41){
		s_trr.linkTrackVars=s_trr.apl(s_trr.linkTrackVars,'events',',',1);
		s_trr.linkTrackVars=s_trr.apl(s_trr.linkTrackVars,'products',',',1);
		s_trr.linkTrackVars=s_trr.apl(s_trr.linkTrackVars,'eVar41',',',1);
		s_trr.linkTrackEvents=s_trr.apl(s_trr.linkTrackEvents,'event18',',',1);
	}
}

s_trr.doPlugins=s_doPlugins

