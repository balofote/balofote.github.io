function _ts_iOV(o){
	var chnnl=o.channel,
		siteid=o.idCrtfc,
		chnnldtl=o.channeldetail,
		typ=o.type,
		url=_ts_C.tL(unescape(document.URL));
	var chnnlA=chnnl.split(".");
	chnnldtl=chnnldtl=="/"?"/":chnnldtl.replace(/^[\s\/]+|[\s\/]+$/g,"");
	typ=typ?typ:"---";
	_ts_cc=chnnlA[0];
	_ts_cc=_ts_cc.match(/^(ar|br|cl|co|ec|en|mx|pe|us|ve)$/)?_ts_cc:"br";

	var ctgry=o.category?o.category:(chnnlA[1]).match(/^(comunidad|comunidade|community)$/)?"comunidades":(chnnlA[1]).match(/^(productosyservicios|produtoseservicos)$/)?"productos_y_servicios":"contenido_digital";

	var srsid="";
	if(_ts_C.tL(terra_info_type)=="www"){
		srsid="par";}
	else{
		switch(ctgry){
			case "entretenimiento_digital_tv":srsid="ttv";
			case "entretenimiento_digital_sonora":srsid="son";
			case "contenido_digital":srsid=chnnlA[1].match(/^(noticias|news|deportes|esportes|sports|entretenimiento|diversao|entertainment|vidayestilo|vidaeestilo|lifestyle)$/)?chnnlA[1].substring(0,3):"";}}
	s_trr_account="terra"+(_ts_cc=="en"?"us":_ts_cc);
	s_trr_account+=(srsid?","+s_trr_account+(srsid=="new"?"not":(srsid=="spo"?"dep":(srsid=="lif"?"vid":srsid))):"");
	s_trr.sa(s_trr_account);
	s_trr.clearVars();

	s_trr.dstStart=_ts_CA[_ts_cc][1];
	s_trr.dstEnd=_ts_CA[_ts_cc][2];
	s_trr.currentYear="2010";

	/* Time parting */
	var temphr=s_trr.getTimeParting('h',_ts_CA[_ts_cc][0]); // Set hour 
	var tempday=s_trr.getTimeParting('d',_ts_CA[_ts_cc][0]); // Set day
	var tempweek=s_trr.getTimeParting('w',_ts_CA[_ts_cc][0]); // Set Weekend / Weekday
	if(temphr){
		s_trr.prop50=tempweek+" : "+tempday+" : "+temphr;
		s_trr.eVar50=tempweek+" : "+tempday+" : "+temphr;}

	var pgnm="",lctn=document.location;
	if(url.indexOf("file:")>=0){
		pgnm="localfile";}
	else{
		var hst=pth="",hstA=(lctn.hostname.toLowerCase()).split("."),pthA=((lctn.pathname.toLowerCase()).replace(/\/(index|default)\.(htm|html|shtml|asp|aspx|php|cfm|jsp)$/,"/")).split("/");
		for(var i=0;i<hstA.length;i++){
			hst=hst+(hstA[i].match(/^(www|terra|com)$/)?"":"."+hstA[i]);}
		hst=hst?hst.substring(1):"us";
		var vA=[[/^(cap|srv|adm)/,"mail"],[/^(cha)$/,"chat"],[/^(blo)$/,"blog"],[/^(fot)$/,"fotolog"]];
		for(var j=0;j<vA.length;j++){
			if(typ.match(vA[j][0])){
				if(hst.match(vA[j][1])){
					var pnt=hst.lastIndexOf(".");
					hst=hst.substring(pnt+1);
					hst=(vA[j][1])+"."+(hst.match(/^(ar|br|cl|co|ec|en|mx|pe|us|ve)$/)?hst:"us");
					pth="/";}}}
		var leA=pthA.length;
		if(typ.match(/^(not|gal)$/)){
			if(leA>0){
				pthA[leA-1]=typ;}}
		else if(typ.match(/^(tbo)$/)){
			if(!(leA>2&&(pthA[leA-1]).match(/\.html?$/))){
				pthA.length=leA-1;}}
		else if(typ.match(/^(www)$/)){
			pth="/";}
		if(pth!="/"){
			pth=pthA.join("/");}
		pgnm=hst+pth.replace(/\/$/,"");
	}

	s_trr.pfxID=chnnlA[0];
	s_trr.server=location.hostname;
	s_trr.channel=s_trr.eVar1=chnnlA[0]+"."+chnnlA[1]+"."+chnnlA[2]+"|"+siteid;
	s_trr.pageType="";/*For 404 Error Page Tracking*/
	s_trr.pageName=s_trr.eVar4=pgnm;

	if(ctgry.match(/^(comunidades|productos_y_servicios)$/)){
		chnnlA[1]=chnnlA[2];}

	s_trr.prop1=chnnldtl;
	s_trr.prop2=ctgry;
	s_trr.prop3=ctgry+"|"+chnnlA[1];
	s_trr.prop4=s_trr.eVar3=siteid;
	s_trr.prop5=s_trr.eVar2=typ;
	s_trr.prop6=ctgry+"|"+chnnlA[1]+"|"+chnnlA[2];
	s_trr.prop7=chnnlA[1];
	s_trr.prop8=chnnlA[2];
	s_trr.prop9=siteid+"|"+chnnldtl+"|"+typ;
	s_trr.prop10=uv_c?uv_c:o.uv_c?o.uv_c:o.channel;
	s_trr.prop11=o.id;
	s_trr.prop12=siteid+"|"+chnnldtl;
	s_trr.prop13=s_trr.eVar5="";
	s_trr.prop14=s_trr.eVar6="";
	s_trr.prop15=s_trr.eVar7="alianza";
	s_trr.prop16=ctgry+"|"+chnnlA[1]+"|"+s_trr.prop15;
	s_trr.prop17="";
	s_trr.prop18=(o.search?o.search:"");
	s_trr.eVar8="";
	s_trr.prop19=s_trr.eVar9="";
	s_trr.prop20=_ts_C.tL((typeof(_ts_ss)!=_ts_U&&_ts_ss!=null&&_ts_ss&&_ts_ss.length<100&&_ts_ss.search(/rtsmoc\.|\/metrics\//i)>0&&_ts_ss.search(/\.js$/i)>0)?_ts_ss:"");
	s_trr.prop31=(typ=="not"?"D=g":"");
	s_trr.prop32=(typ=="gal"?"D=g":"");
	if(s_trr.prop15=="alianza"){
		s_trr.eVar42="D=pageName";
		s_trr.eVar43="D=g";}
	else{
		s_trr.eVar44="D=pageName";
		s_trr.eVar45="D=g";}
	s_trr.hier1=ctgry+"|"+chnnlA[1]+"|"+chnnlA[2]+"|"+siteid+"|"+typ;
	s_trr.hier2=s_trr.prop15+"|"+ctgry+"|"+chnnlA[1]+"|"+chnnlA[2]+"|"+siteid+"|"+typ;
	/* Internal Search */
	s_trr.events=s_trr.prop18?s_trr.apl(s_trr.events,'event17',',',1):s_trr.events;
}
}

